# simple-rss-notifications — environment template
#
# Copy to .env and fill in. scripts/install.sh will auto-generate secrets
# for you on first run. NEVER commit .env to git.

# ── Docker image tags (deploy plumbing) ─────────────────────────────────────
WEB_IMAGE=ghcr.io/jason-tucker/simple-rss-notifications-web:latest
CADDY_IMAGE=ghcr.io/jason-tucker/simple-rss-notifications:latest

# Loopback port Caddy binds to on the host. Cloudflared (running OUTSIDE
# this stack) reaches Caddy at 127.0.0.1:${PORT}. NEVER expose to 0.0.0.0.
PORT=6082

# Stable alias on the docker network. Lets Caddy reach Next by name.
NEXT_HOST=next-srn
NEXT_ALIAS=next-srn

# ── Public URL (source of truth — never hardcode anywhere else) ─────────────
# Used for cookie domain, CSRF origin, OAuth redirects (future), etc.
PUBLIC_BASE_URL=https://feeds.example.com

# ── Database ────────────────────────────────────────────────────────────────
# install.sh auto-generates a strong POSTGRES_PASSWORD on first run.
POSTGRES_DB=srn
POSTGRES_USER=srn
POSTGRES_PASSWORD=change_me

# ── Cryptographic secrets ───────────────────────────────────────────────────
# 64 random hex chars (32 bytes) — signs session JWTs. install.sh generates this.
SESSION_SECRET=change_me_64_hex

# 64 random hex chars (32 bytes) — AES-256-GCM key for at-rest secret encryption
# (SMTP passwords, Resend API keys, ntfy bearer tokens). App refuses to start
# without it. install.sh generates this.
APP_ENCRYPTION_KEY=change_me_64_hex

# ── Bootstrap (first-boot seed, only runs when users table is empty) ────────
# A single admin user is created with this username/password and a forced
# password-change banner on first login. Set BOOTSTRAP_USERNAME=skip to disable.
BOOTSTRAP_USERNAME=tucker
# Set a strong password; scripts/install.sh generates one for you. Must NOT be
# 'admin' — the worker refuses to seed an admin with an empty or 'admin'
# password (no default-credentials admin can be shipped).
BOOTSTRAP_PASSWORD=

# NOTE: no WATCHTOWER_* vars. We rely on the host's single nickfedor/watchtower
# (run by another stack on this VPS) to auto-pull our :latest images. Our
# containers carry `com.centurylinklabs.watchtower.enable=true` labels.
