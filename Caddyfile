# simple-rss-notifications — Caddy ingress.
#
# Listens on :${PORT:-6082} INSIDE the docker network. No host port mapping
# beyond a 127.0.0.1 loopback bind in docker-compose.yml — Cloudflare Tunnel
# (running standalone on the host) is the only public ingress.

{
  # Cloudflare terminates TLS at the edge.
  auto_https off
  # No `caddy reload` from inside the container.
  admin off
}

:{$PORT:6082} {
  encode gzip zstd

  # Next.js fingerprints filenames under /_next/static (e.g. .../[hash].js),
  # so the contents at a given URL never change. Tell the browser to cache
  # forever — saves a re-download on every page load.
  @nextStatic path /_next/static/*
  header @nextStatic Cache-Control "public, max-age=31536000, immutable"

  # Same idea for the favicon + Next-served icon routes — they're keyed
  # by app/icon.png etc.; if the file changes, the URL hash changes.
  @nextIcons path /icon /icon.png /apple-icon /apple-icon.png /favicon.ico
  header @nextIcons Cache-Control "public, max-age=86400"

  # Fall back to a minimal landing page if Next is down or returning 5xx,
  # so the user never sees a blank Cloudflare error.
  handle_errors {
    @5xx expression `{err.status_code} >= 500`
    handle @5xx {
      root * /srv/landing
      rewrite * /502.html
      file_server
    }
  }

  reverse_proxy {$NEXT_HOST:next-srn}:3000 {
    fail_duration 5s
    max_fails 2
    lb_try_duration 2s
  }
}
