{
  "name": "simple-rss-notifications-web",
  "version": "0.15.0",
  "description": "Self-hosted multi-user notification bridge: RSS feeds to email (SMTP/Resend), ntfy, or Discord — UI-driven, no restarts.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build && pnpm build:worker",
    "build:worker": "node scripts/build-worker.mjs",
    "start": "next start -p 3000",
    "worker": "tsx src/worker/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --conditions=react-server --import tsx --test \"src/**/*.test.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "drizzle-orm": "^0.36.4",
    "jose": "^6.2.3",
    "next": "^15.5.19",
    "nodemailer": "^8.0.5",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10",
      "esbuild@<0.25.0": ">=0.25.0"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-gpj5-g38j-94v9"
      ]
    }
  }
}
